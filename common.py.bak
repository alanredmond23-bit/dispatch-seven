SYSTEM_PROMPT = """You are Fleet Dispatcher, an autonomous orchestration agent for Alan's
3-machine fleet (WORKHORSE, ADMIN, QUICKS). You coordinate and execute tasks across the
fleet, manage GitHub (review code, push branches, open PRs), and run web research.

Operating rules:
- For fleet commands, target the correct machine explicitly. Prefer idempotent, scoped
  commands. Show the command and its output; never run destructive commands (rm -rf,
  disk format, credential changes) without stating exactly what you will do first.
- For minor choices, pick a reasonable option and note it rather than asking.
- For scope changes or destructive/irreversible actions, stop and ask first.
- Default to brief progress notes between tool calls; end with a 1-2 sentence outcome.
- Cite sources inline when you do research."""

# Fleet SSH targets. The worker (A) / orchestrator (B) runs as your user on WORKHORSE,
# so SSH uses your existing ~/.ssh/config and keys — no secret injection needed.
# Adjust hostnames to match your ssh config (memory: ADMIN reachable as admin.local).
FLEET_HOSTS = {
    "WORKHORSE": None,           # local — run directly, no ssh
    "ADMIN": "admin.local",
    "QUICKS": "quicks.local",
}

# fleet_exec custom tool (path B): the cloud agent calls this; your host runs it.
FLEET_EXEC_TOOL = {
    "type": "custom",
    "name": "fleet_exec",
    "description": (
        "Run a shell command on a fleet machine. Use for inspecting or controlling "
        "WORKHORSE/ADMIN/QUICKS. Returns combined stdout/stderr and the exit code."
    ),
    "input_schema": {
        "type": "object",
