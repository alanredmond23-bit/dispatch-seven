# D7 Frontend — Environment Variables
# Copy to .env.local — NEVER commit real values

# WebSocket backend URL
# Dev:  ws://localhost:3001
# Prod: wss://your-aca-app.azurecontainerapps.io
VITE_WS_URL=

# Optional: Anthropic key for direct fallback (legacy — prefer WS transport)
VITE_ANTHROPIC_API_KEY=

# Optional: override Vite base path for GitHub Pages
VITE_BASE_PATH=/
