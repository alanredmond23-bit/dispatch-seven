# D7 Backend — Environment Variables
# Copy to .env.local — NEVER commit real values
# All secrets live in: menagerie-kv-37040

# ── ANTHROPIC ──
ANTHROPIC_API_KEY=

# ── SUPABASE ──
SUPABASE_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE=

# ── AZURE KEY VAULT ──
AZURE_KEY_VAULT_URI=https://menagerie-kv-37040.vault.azure.net
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── BUDGET CAP ──
# Hard per-session spend cap in USD. Default 1.00 if unset.
BUDGET_CAP_USD=1.00

# ── LANGFUSE OBSERVABILITY ──
# Get keys at: https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── MEM0 CLOUD MEMORY LAYER ──
# https://app.mem0.ai → API Keys
MEM0_API_KEY=

# ── LEGAL CITATION RAG ──
# CourtListener API key — used by citation-extractor.ts
# Get a free key at: https://www.courtlistener.com/sign-in/ → API Tokens
COURTLISTENER_API_KEY=

# ── AUTH / API ──
# Bearer token required on all /api/* routes
API_BEARER_TOKEN=

# ── CORS ──
CORS_ORIGINS=http://localhost:5173

PORT=3001
